# ─── Internal API auth ───
# Required in production for /api/import, /api/search, /api/trends, /api/scrape.
# If unset in prod, those routes return 503 (api disabled).
# Clients must send `x-pv-secret: <value>` header.
PV_API_SECRET=cambiar-esto-en-prod

# ─── Scraper kill-switch (Puppeteer) ───
# /api/scrape is dev-only by default. Set to "true" in Vercel only when
# you intentionally want to enable Puppeteer-driven scraping in prod.
ENABLE_SCRAPE=false

# ─── MercadoLibre OAuth ───
# Used by lib/mercadolibre.ts when calling endpoints that require auth
# (e.g. /trends/MLA). Public endpoints fall through without it.
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=
ML_APP_ID=
ML_SECRET=

# ─── Site config ───
NEXT_PUBLIC_SITE_URL=https://productosvirales.com.ar
NEXT_PUBLIC_GA_ID=
